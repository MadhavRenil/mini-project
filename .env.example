# SerpApi key (required for live flights, hotels, and events)
# SERPAPI_KEY=your_serpapi_key_here

# Optional: RapidAPI key for hotel and fuel providers
# RAPIDAPI_KEY=your_rapidapi_key_here

# Optional: Google Maps (route map). Required Google API for current app: Maps JavaScript API.
# Optional Google APIs for future features: Places API, Geocoding API, Directions API.
# Get key at https://console.cloud.google.com/apis/credentials
# GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Optional: Hotel API host (default: booking-com15.p.rapidapi.com). Subscribe to a hotel API on RapidAPI.
# HOTEL_API_HOST=booking-com15.p.rapidapi.com

# Server port (default 3003)
# PORT=3000

# OpenAI API Key (for smart itinerary generation)
# OPENAI_API_KEY=sk-...

# Gemini API Key (alternative AI itinerary provider)
# GEMINI_API_KEY=your_gemini_api_key_here

# Amadeus is no longer used in the live flight pipeline.
