# SerpApi key (required for live flight + hotel data)
# SERPAPI_KEY=your_serpapi_key_here

# Optional: Real-time APIs (same key for Skyscanner, hotels, fuel on RapidAPI)
# RAPIDAPI_KEY=your_rapidapi_key_here

# Optional: Google Maps (route map). Required Google API for current app: Maps JavaScript API.
# Optional Google APIs for future features: Places API, Geocoding API, Directions API.
# Get key at https://console.cloud.google.com/apis/credentials
# GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Optional: Hotel API host (default: booking-com13.p.rapidapi.com). Subscribe to a hotel API on RapidAPI.
# HOTEL_API_HOST=booking-com13.p.rapidapi.com

# Server port (default 3003)
# PORT=3000

# OpenAI API Key (for smart itinerary generation)
# OPENAI_API_KEY=sk-...

# Amadeus API Keys (for real flight/hotel data)
# AMADEUS_CLIENT_ID=your_client_id
# AMADEUS_CLIENT_SECRET=your_client_secret
