# Share this file with your team. Do NOT put real secrets in this file.
# Copy to .env locally and fill with real values.

# App
PORT=3000
SESSION_SECRET=change_me_to_a_long_random_secret

# Required for current app features
SERPAPI_KEY=your_serpapi_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Optional / legacy integrations in this repo
RAPIDAPI_KEY=your_rapidapi_key
HOTEL_API_HOST=booking-com13.p.rapidapi.com
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret
OPENAI_API_KEY=your_openai_api_key
